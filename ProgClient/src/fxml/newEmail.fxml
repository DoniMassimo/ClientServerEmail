            </HBox>
         </children>
      </GridPane>
      <HBox alignment="CENTER" prefHeight="100.0" prefWidth="200.0" GridPane.rowIndex="1">
         <children>
            <Label fx:id="lblError" textFill="#ee0303" />
         </children>
      </HBox>
   </children>
</GridPane>
